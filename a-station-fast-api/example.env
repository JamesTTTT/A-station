# Database Configuration
POSTGRES_USER=a_station_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=a_station_db
DATABASE_URL=postgresql://a_station_user:your_secure_password_here@localhost:5432/a_station_db

# Security Configuration
# Generate a secure key with: openssl rand -hex 32
SECRET_KEY=your_secret_key_here_replace_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Application
PROJECT_NAME=A-Station
VERSION=0.1.0

# CORS Origins (comma-separated for production)
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Optional: GitHub OAuth
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=